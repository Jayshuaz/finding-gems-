generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum PlaceCategory {
  property
  food
  entertainment
  lifestyle
  shopping
  essentials
  education
  outdoor
}

enum SignalType {
  new_place
  price_drop
  price_surge
  event_upcoming
  promotion
  trending
  availability
  traffic_anomaly
}

enum UserRole {
  USER
  PREMIUM
  VENUE_OWNER
  ADMIN
}

// ─── Core Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  isPremium     Boolean   @default(false)
  searchQuota   Int       @default(10)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  searches      ConciergeSearch[]
  savedPlaces   SavedPlace[]
  preferences   UserPreferences?

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id             String         @id @default(cuid())
  userId         String         @unique
  defaultRadiusM Int            @default(5000)
  favorites      PlaceCategory[]
  budgetMin      Int?
  budgetMax      Int?
  notifications  Boolean        @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Places ───

model Place {
  id                String        @id @default(cuid())
  name              String
  category          PlaceCategory
  subcategory       String?
  description       String?       @db.Text
  latitude          Float
  longitude         Float
  address           String?
  city              String?
  country           String        @default("KE")
  priceMin          Int?
  priceMax          Int?
  phone             String?
  email             String?
  website           String?
  socialLinks       Json?         @default("{}")
  hours             Json?         @default("{}")
  amenities         String[]      @default([])
  scores            Json?         @default("{}")
  metadata          Json?         @default("{}")
  source            String        @default("manual")
  sourceId          String?
  isFeatured        Boolean       @default(false)
  featuredUntil     DateTime?
  isGem             Boolean       @default(false)
  gemExplanation    String?       @db.Text
  reviewCount       Int           @default(0)
  averageRating     Float          @default(0)
  monthlyVisitors   Int           @default(0)
  gemExpiresAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  signals           Signal[]
  events            Event[]
  savedPlace        SavedPlace[]
  sponsoredPlacements SponsoredPlacement[]

  @@index([latitude, longitude])
  @@index([category])
  @@index([isGem])
  @@index([isFeatured])
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
}

// ─── Signals ───

model Signal {
  id        String     @id @default(cuid())
  type      SignalType
  placeId   String?
  title     String
  body      String?
  score     Float      @default(0.5)
  metadata  Json?      @default("{}")
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([expiresAt])
}

// ─── Events ───

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  venueId     String?
  startTime   DateTime
  endTime     DateTime?
  category    String?
  priceMin    Int?
  priceMax    Int?
  source      String   @default("manual")
  sourceId    String?
  imageUrl    String?
  ticketUrl   String?
  createdAt   DateTime @default(now())

  venue Place? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([startTime])
  @@index([venueId])
  @@index([category])
}

// ─── Concierge ───

model ConciergeSearch {
  id            String   @id @default(cuid())
  userId        String?
  query         String
  extractedParams Json?
  resultsCount  Int      @default(0)
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── Sponsorship ───

model SponsoredPlacement {
  id          String   @id @default(cuid())
  placeId     String
  campaignId  String
  bidAmount   Float
  budgetDaily Float
  budgetTotal Float
  startsAt    DateTime @default(now())
  endsAt      DateTime?

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}